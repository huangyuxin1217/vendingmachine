/* pages/product/detail.wxss */
.container {
  padding-bottom: 120rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 500rpx;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.product-image {
  width: 100%;
  height: 500rpx;
  background-color: #f5f5f5;
}

.product-info {
  padding: 30rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.product-price {
  font-size: 46rpx;
  font-weight: bold;
  color: #e74c3c;
  margin-bottom: 20rpx;
}

.product-stock-info {
  margin-bottom: 30rpx;
}

.stock {
  font-size: 26rpx;
  color: #666;
  padding: 6rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
}

.low-stock {
  color: #fff;
  background-color: #e74c3c;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.product-description {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.quantity-section {
  display: flex;
  flex-direction: column;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #ddd;
  font-size: 36rpx;
  color: #333;
}

.quantity-display {
  width: 80rpx;
  height: 60rpx;
  border-top: 1rpx solid #ddd;
  border-bottom: 1rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  display: flex;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.cart-btn, .buy-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.cart-btn {
  background-color: #f8f8f8;
  color: #333;
}

.buy-btn {
  background-color: #e74c3c;
  color: #fff;
}