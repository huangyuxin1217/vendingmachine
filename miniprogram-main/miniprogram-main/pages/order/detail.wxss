/* pages/order/detail.wxss */
.container {
    padding: 20rpx;
    min-height: 100vh;
    background-color: #f5f5f5;
    padding-bottom: 150rpx;
  }
  
  /* 加载中 */
  .loading-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
  }
  
  .loading-icon {
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 20rpx;
  }
  
  /* 卡片通用样式 */
  .section-card {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  }
  
  .section-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    border-left: 6rpx solid #e74c3c;
    padding-left: 16rpx;
  }
  
  /* 订单状态 */
  .status-card {
    background-color: #e74c3c;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    color: #fff;
  }
  
  .status-title {
    display: flex;
    align-items: center;
    margin-bottom: 16rpx;
  }
  
  .status {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .status-desc {
    font-size: 26rpx;
    opacity: 0.8;
  }
  
  /* 商品列表 */
  .product-list {
    border-top: 1rpx solid #f5f5f5;
    padding-top: 20rpx;
  }
  
  .product-item {
    display: flex;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f5f5f5;
  }
  
  .product-item:last-child {
    border-bottom: none;
  }
  
  .product-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 8rpx;
    background-color: #f5f5f5;
    margin-right: 20rpx;
  }
  
  .product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  .product-name {
    font-size: 28rpx;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  .product-price-qty {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .product-price {
    color: #e74c3c;
    font-size: 32rpx;
    font-weight: bold;
  }
  
  .product-qty {
    color: #999;
    font-size: 28rpx;
  }
  
  /* 订单信息 */
  .info-item {
    display: flex;
    justify-content: space-between;
    padding: 16rpx 0;
    font-size: 28rpx;
    color: #666;
  }
  
  .info-item.total {
    border-top: 1rpx dashed #eee;
    padding-top: 20rpx;
    margin-top: 10rpx;
  }
  
  .price {
    color: #e74c3c;
    font-weight: bold;
    font-size: 32rpx;
  }
  
  /* 底部操作栏 */
  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #fff;
    padding: 20rpx;
    display: flex;
    justify-content: flex-end;
    box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  }
  
  .footer button {
    margin-left: 20rpx;
    font-size: 28rpx;
    padding: 16rpx 40rpx;
  }
  
  .btn-cancel {
    color: #666;
    background-color: #f5f5f5;
    border: 1rpx solid #ddd;
  }
  
  .btn-pay {
    color: #fff;
    background-color: #e74c3c;
  }
  
  .btn-refund {
    color: #666;
    background-color: #f5f5f5;
    border: 1rpx solid #ddd;
  }
  
  .btn-rebuy {
    color: #fff;
    background-color: #e74c3c;
  }