/* pages/location/index.wxss */

.refresh-btn {
  position: fixed;
  bottom: 30px;
  right: 20px;
  background: #fff;
  padding: 10px;
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.refresh-btn .icon {
  width: 32px;
  height: 32px;
  margin-bottom: 5px;
}

.refresh-btn cover-text {
  font-size: 12px;
  color: #333;
}

.loading-indicator {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.6);
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  z-index: 100;
}

.loading-text {
  color: white;
  font-size: 28rpx;
}