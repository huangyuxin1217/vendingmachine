/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #aaa;
  width: 80%;
}

.userinfo-avatar {
  overflow: hidden;
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.usermotto {
  margin-top: 200px;
}

.avatar-wrapper {
  padding: 0;
  width: 56px !important;
  border-radius: 8px;
  margin-top: 40px;
  margin-bottom: 40px;
}

.avatar {
  display: block;
  width: 56px;
  height: 56px;
}

.nickname-wrapper {
  display: flex;
  width: 100%;
  padding: 16px;
  box-sizing: border-box;
  border-top: .5px solid rgba(0, 0, 0, 0.1);
  border-bottom: .5px solid rgba(0, 0, 0, 0.1);
  color: black;
}

.nickname-label {
  width: 105px;
}

.nickname-input {
  flex: 1;
}

.container {
  padding: 20rpx;
}

/* 轮播图样式 */
swiper {
  height: 350rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

swiper-item image {
  width: 100%;
  height: 100%;
}

/* 商品网格样式 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2px 6px rgba(0,0,0,0.05);
  transition: all 0.3s ease;
  position: relative;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 200rpx;
  background-color: #f9f9f9;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: bold;
}

/* 添加到现有的 pages/index/index.wxss 文件底部 */

.loading-tip {
  text-align: center;
  padding: 10rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.product-stock {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.low-stock {
  color: #fff;
  background-color: #e74c3c;
}

/* 添加到 pages/index/index.wxss 底部 */
.action-bar {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.cart-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #ffffff00;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  width: 36rpx;
  height: 36rpx;
}
